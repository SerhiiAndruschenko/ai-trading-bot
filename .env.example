# ── Binance API ───────────────────────────────────────────────────────────────
# Testnet: https://testnet.binancefuture.com
# Mainnet: https://www.binance.com/en/my/settings/api-management
API_KEY=
API_SECRET=

# ── Google Gemini API ─────────────────────────────────────────────────────────
# Отримати на: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Назва моделі (за замовчуванням gemini-2.0-flash)
# Інші варіанти: gemini-1.5-pro, gemini-2.0-flash-lite, gemini-2.5-pro-preview-05-06
GEMINI_MODEL=gemini-2.0-flash

# ── Telegram ──────────────────────────────────────────────────────────────────
# BOT_TOKEN — від @BotFather
# CHAT_ID   — ваш chat_id (дізнатись через @userinfobot)
# THREAD_ID — (опціонально) id теми в групі
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=

# ── Торгові параметри ─────────────────────────────────────────────────────────
MAX_TRADING_BALANCE=500
MAX_OPEN_TRADES_GLOBAL=2

# ── Шлях до файлу стану ───────────────────────────────────────────────────────
# За замовчуванням — директорія проєкту
STATE_DIR=.
