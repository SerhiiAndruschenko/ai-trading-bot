# Binance API
# Testnet: https://testnet.binancefuture.com
API_KEY=
API_SECRET=

# Google Gemini API — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Model name (default: gemini-2.5-pro)
# Available options (from your account):
#   gemini-2.5-pro           (stable, recommended)
#   gemini-2.5-flash         (faster, cheaper)
#   gemini-3.1-pro-preview   (latest preview)
#   gemini-3-pro-preview
GEMINI_MODEL=gemini-2.5-pro

# Telegram (optional)
# BOT_TOKEN from @BotFather, CHAT_ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=

# Trading parameters
MAX_TRADING_BALANCE=500
MAX_OPEN_TRADES_GLOBAL=2

# Path to state file (default: project directory)
STATE_DIR=.
